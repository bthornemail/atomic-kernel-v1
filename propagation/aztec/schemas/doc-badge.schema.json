{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atomic-kernel.doc.badge/1",
  "title": "Atomic Kernel Document Verification Badge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "authority",
    "doc_id",
    "doc_path",
    "release",
    "version",
    "hash_alg",
    "doc_hash",
    "artifacts_ref",
    "verify_mode"
  ],
  "properties": {
    "schema": { "const": "atomic-kernel.doc.badge/1" },
    "authority": { "const": "projection" },
    "doc_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "doc_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_./-]+$"
    },
    "release": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "version": { "const": 1 },
    "hash_alg": { "const": "sha256" },
    "doc_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifacts_ref": {
      "type": "string",
      "pattern": "^releases/[0-9]+\\.[0-9]+\\.[0-9]+/ARTIFACTS\\.sha256$"
    },
    "verify_mode": { "const": "hash-match" }
  }
}
