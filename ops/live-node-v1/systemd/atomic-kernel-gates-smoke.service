[Unit]
Description=Atomic Kernel Gate Smoke Cycle
After=network-online.target atomic-kernel-mcp.service
Wants=network-online.target atomic-kernel-mcp.service

[Service]
Type=oneshot
WorkingDirectory=/opt/atomic-kernel
EnvironmentFile=/etc/atomic-kernel/node.env
ExecStart=/bin/bash -lc 'npm run -s mcp:unified:smoke && npm run -s mcp:unified:stdio:smoke'
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true

