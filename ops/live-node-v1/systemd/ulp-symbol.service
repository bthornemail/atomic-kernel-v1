[Unit]
Description=ULP Symbol Interpreter Service
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/atomic-kernel
ExecStart=/usr/bin/node /opt/atomic-kernel/runtime/ulp/symbol-service.mjs
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/atomic-kernel

[Install]
WantedBy=multi-user.target
