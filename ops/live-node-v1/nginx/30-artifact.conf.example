server {
    listen 80;
    listen [::]:80;
    server_name artifact.universal-life-protocol.com;

    # Read-only artifact surface.
    root /opt/atomic-kernel/artifacts;
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    location / {
        limit_except GET HEAD {
            deny all;
        }
        try_files $uri $uri/ =404;
    }
}
