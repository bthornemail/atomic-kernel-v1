  match n with
  | 0 => []
  | S n' => x :: sequence n' (oscillate x)
  end.

Fixpoint readings (n : nat) (x : state) : list band :=
  match n with
  | 0 => []
  | S n' => classify x :: readings n' (oscillate x)
  end.

